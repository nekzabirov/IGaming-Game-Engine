# ===========================================
# casino-engine Configuration
# ===========================================

# --- Server Ports ---
HTTP_PORT=8080
GRPC_PORT=5050

# --- Database (PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://localhost:5432/game_db
DATABASE_USER=game_user
DATABASE_PASSWORD=game_secret

# --- Wallet Service (gRPC) ---
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=5555

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- S3 Storage (MinIO / AWS S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=casino-engine

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=casino-engine
