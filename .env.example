# ===========================================
# casino-engine Configuration
# ===========================================

# --- Server Ports ---
HTTP_PORT=8080
GRPC_PORT=5050

# --- Database (PostgreSQL) ---
# Base URL without DB name. Casino DB ("casino") is created by /app/bin/db-migrate.
DB_URL=jdbc:postgresql://localhost:5432
DB_USERNAME=user
DB_PASSWORD=password

# --- Wallet Service (gRPC) ---
WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=5555

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- S3 Storage (MinIO / AWS S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=casino-engine

# --- RabbitMQ ---
# Exchange name is hardcoded as "casino-engine" — see infrastructure/rabbitmq/RabbitMqConstants.kt.
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
